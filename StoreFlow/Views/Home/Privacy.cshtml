@{
    ViewData["Title"] = "Privacy Policy";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">@ViewData["Title"]</h4>
                <div class="alert alert-fill-info d-flex align-items-center" role="alert">
                    <i class="mdi mdi-shield-check mr-2"></i>
                    Sitenizin gizlilik politikasını detaylandırmak için bu sayfayı kullanın.
                </div>
                <div class="mt-4">
                    <p class="text-muted">
                        Bu alan kullanıcı verilerinin güvenliği, işlenmesi ve saklanmasıyla ilgili yasal bilgilendirmeleri içermektedir.
                        İlgili metinleri kurum politikalarınıza göre buradan düzenleyebilirsiniz.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>