@model List<Category>
@{
    ViewData["Title"] = "ReverseCategory";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="card-title mb-0">Tersten Kategori Listesi</h3>
                    <div>
                        <span class="badge badge-info p-2 mr-2">İlk Kategori: @ViewBag.CategoryValue</span>
                        <span class="badge badge-dark p-2">Sorgu Sonucu: @ViewBag.CategoryValue2</span>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Kategori Adı</th>
                                <th>Durum</th>
                                <th class="text-center">Sil</th>
                                <th class="text-center">Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th>@item.CategoryId</th>
                                    <td>@item.CategoryName</td>
                                    <td>
                                        @if (item.CategoryStatus)
                                        {
                                            <span class="badge badge-success badge-pill">Aktif Kategori</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger badge-pill">Pasif Kategori</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Category" asp-action="DeleteCategory" asp-route-id="@item.CategoryId" class="btn btn-outline-danger btn-sm">Sil</a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Category" asp-action="UpdateCategory" asp-route-id="@item.CategoryId" class="btn btn-outline-success btn-sm">Güncelle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-4">
                        <a asp-controller="Category" asp-action="CreateCategory" class="btn btn-primary">Yeni Kategori Girişi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>