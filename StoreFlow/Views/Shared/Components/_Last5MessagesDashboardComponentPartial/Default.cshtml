@model List<Message>

<div class="row">
    <div class="col-12 grid-margin">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="card-title">
                    <i class="mdi mdi-email-open-outline text-primary mr-2"></i>
                    Gelen Son 5 Mesaj
                </h4>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th style="width: 40px;">#</th>
                                <th>Görsel</th>
                                <th>Gönderen</th>
                                <th>Durum</th>
                                <th>Mesaj Özeti</th>
                                <th class="text-right">İşlem</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="form-check">
                                                <label class="form-check-label">
                                                    <input type="checkbox" class="form-check-input">
                                                    <i class="input-helper"></i>
                                                </label>
                                            </div>
                                        </td>
                                        <td class="py-1">
                                            <img src="@(string.IsNullOrEmpty(item.SenderImageUrl) ? "/images/faces/default-user.png" : item.SenderImageUrl)" alt="profile" class="img-sm rounded-circle" />
                                        </td>
                                        <td class="font-weight-bold text-dark">
                                            @item.SenderNameSurname
                                        </td>
                                        <td>
                                            <label class="badge badge-outline-info badge-pill">Gelen Kutusu</label>
                                        </td>
                                        <td class="text-muted text-truncate" style="max-width: 300px;">
                                            @item.MessageDetail
                                        </td>
                                        <td class="text-right">
                                            <button class="btn btn-outline-light btn-sm border-0 text-dark" type="button">
                                                <i class="mdi mdi-dots-vertical"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        Okunmamış mesaj bulunmuyor.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>