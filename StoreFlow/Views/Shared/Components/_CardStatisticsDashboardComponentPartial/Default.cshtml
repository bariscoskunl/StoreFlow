<div class="row grid-margin">
    <div class="col-12">
        <div class="card card-statistics shadow-sm">
            <div class="card-body">
                <div class="d-flex flex-column flex-md-row align-items-center justify-content-between">
                    
                    <div class="statistics-item text-center text-md-left">
                        <p class="text-muted mb-2">
                            <i class="mdi mdi-account-multiple mr-2 text-primary"></i>
                            Müşteri Sayısı
                        </p>
                        <h2 class="font-weight-bold">@ViewBag.totalCustomerCount</h2>
                        <label class="badge badge-outline-success badge-pill">@DateTime.Now.ToString("MMMM") İvmesi</label>
                    </div>

                    <div class="statistics-item text-center text-md-left">
                        <p class="text-muted mb-2">
                            <i class="mdi mdi-tag-multiple mr-2 text-danger"></i>
                            Toplam Kategori
                        </p>
                        <h2 class="font-weight-bold">@ViewBag.totalCategoryCount</h2>
                        <label class="badge badge-outline-info badge-pill">Aktif Gruplar</label>
                    </div>

                    <div class="statistics-item text-center text-md-left">
                        <p class="text-muted mb-2">
                            <i class="mdi mdi-cube-outline mr-2 text-warning"></i>
                            Toplam Ürün
                        </p>
                        <h2 class="font-weight-bold">@ViewBag.totalProductCount</h2>
                        <label class="badge badge-outline-primary badge-pill">Stoktaki Çeşit</label>
                    </div>

                    <div class="statistics-item text-center text-md-left">
                        <p class="text-muted mb-2">
                            <i class="mdi mdi-wallet-outline mr-2 text-success"></i>
                            Ort. Müşteri Bakiyesi
                        </p>
                        <h2 class="font-weight-bold">@ViewBag.avgCustomerBalance</h2>
                        <label class="badge badge-outline-success badge-pill">Bakiye Ortalaması</label>
                    </div>

                    <div class="statistics-item text-center text-md-left">
                        <p class="text-muted mb-2">
                            <i class="mdi mdi-cart-outline mr-2 text-info"></i>
                            Toplam Sipariş Sayısı
                        </p>
                        <h2 class="font-weight-bold">@ViewBag.totalOrderCount</h2>
                        <label class="badge badge-outline-success badge-pill">Satış Performansı</label>
                    </div>

                    <div class="statistics-item text-center text-md-left border-0">
                        <p class="text-muted mb-2">
                            <i class="mdi mdi-package-variant mr-2 text-dark"></i>
                            Sipariş Edilen Ürün
                        </p>
                        <h2 class="font-weight-bold">@ViewBag.sumOrderProductCount</h2>
                        <label class="badge badge-outline-secondary badge-pill">Toplam Miktar</label>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>