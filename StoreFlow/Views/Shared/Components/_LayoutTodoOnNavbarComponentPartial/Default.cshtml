@model List<Todo>

<li class="nav-item dropdown">
    <a class="nav-link count-indicator dropdown-toggle" id="notificationDropdown" href="#" data-toggle="dropdown">
        <i class="mdi mdi-bell-outline mx-0"></i>
        @if (ViewBag.todoTotalCount > 0)
        {
            <span class="count bg-warning"></span>
        }
    </a>
    <div class="dropdown-menu dropdown-menu-right navbar-dropdown preview-list" aria-labelledby="notificationDropdown">
        <div class="dropdown-item">
            <p class="mb-0 font-weight-normal float-left">
                Toplam <strong>@ViewBag.todoTotalCount</strong> görev tanımlı
            </p>
            <a asp-controller="Todo" asp-action="TodoList" class="badge badge-pill badge-warning float-right text-dark" style="text-decoration: none;">Tümünü Gör</a>
        </div>
        <div class="dropdown-divider"></div>

        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                string colorClass = "";
                string iconClass = "mdi-information-outline";

                switch (item.Priority)
                {
                    case "Birincil":
                        colorClass = "bg-danger";
                        iconClass = "mdi-alert-octagon-outline";
                        break;
                    case "İkincil":
                        colorClass = "bg-warning";
                        iconClass = "mdi-alert-outline";
                        break;
                    case "Üçüncül":
                        colorClass = "bg-info";
                        iconClass = "mdi-help-circle-outline";
                        break;
                    case "Dördüncül":
                        colorClass = "bg-secondary";
                        iconClass = "mdi-dots-horizontal-circle-outline";
                        break;
                    default:
                        colorClass = "bg-primary";
                        break;
                }

                <a class="dropdown-item preview-item" asp-controller="Todo" asp-action="UpdateTodo" asp-route-id="@item.TodoId">
                    <div class="preview-thumbnail">
                        <div class="preview-icon @colorClass">
                            <i class="mdi @iconClass mx-0 text-white"></i>
                        </div>
                    </div>
                    <div class="preview-item-content">
                        <h6 class="preview-subject font-weight-medium text-dark">@item.Description</h6>
                        <p class="font-weight-light small-text mb-0 text-muted">
                            Öncelik: @item.Priority
                        </p>
                    </div>
                </a>
                <div class="dropdown-divider"></div>
            }
        }
        else
        {
            <div class="dropdown-item text-center">
                <p class="mb-0 text-muted small">Aktif görev bulunmuyor.</p>
            </div>
        }
    </div>
</li>