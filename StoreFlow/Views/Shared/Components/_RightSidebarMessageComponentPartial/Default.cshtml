@model List<Message>

<div class="tab-pane fade" id="chats-section" role="tabpanel" aria-labelledby="chats-section">
    <div class="d-flex align-items-center justify-content-between border-bottom">
        <p class="settings-heading border-top-0 mb-3 pl-3 pt-0 border-bottom-0 pb-0">Okunmamış Mesajlar</p>
        <a asp-controller="Message" asp-action="MessageList" class="settings-heading border-top-0 mb-3 pt-0 border-bottom-0 pb-0 pr-3 font-weight-normal text-primary">Tümünü Gör</a>
    </div>
    <ul class="chat-list">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <li class="list active">
                    <div class="profile">
                        <img src="@(string.IsNullOrEmpty(item.SenderImageUrl) ? "/images/faces/default-user.png" : item.SenderImageUrl)" alt="image">
                        <span class="online"></span>
                    </div>
                    <div class="info">
                        <p class="font-weight-bold">@item.SenderNameSurname</p>
                        <p class="text-muted text-truncate" style="max-width: 150px;">@item.MessageTitle</p>
                    </div>
                    <div class="ml-auto text-right">
                        <small class="text-muted d-block">@item.Datetime.ToString("HH:mm")</small>
                        <span class="badge badge-primary badge-pill" style="font-size: 8px;">Yeni</span>
                    </div>
                </li>
            }
        }
        else
        {
            <li class="list">
                <div class="info">
                    <p class="text-muted">Yeni mesajınız bulunmuyor.</p>
                </div>
            </li>
        }
    </ul>
</div>