@model List<Todo>

<div class="col-md-7 grid-margin stretch-card">
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="card-title">
                <i class="mdi mdi-playlist-check text-primary mr-2"></i>
                Yapılacaklar Listesi
            </h4>
            <div class="add-items d-flex">
                <input type="text" class="form-control todo-list-input" placeholder="Bugün neye ihtiyacınız var?">
                <button class="add btn btn-primary font-weight-bold todo-list-add-btn" id="add-task">Ekle</button>
            </div>
            <div class="list-wrapper">
                <ul class="d-flex flex-column-reverse todo-list">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <li class="@(item.Status ? "completed" : "")">
                                <div class="form-check">
                                    <label class="form-check-label">
                                        <input class="checkbox" type="checkbox" @(item.Status ? "checked" : "")>
                                        @item.Description
                                        <i class="input-helper"></i>
                                    </label>
                                </div>
                                <i class="remove mdi mdi-close-circle-outline"></i>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-center py-3">
                            <span class="text-muted small">Henüz eklenmiş bir görev bulunmuyor.</span>
                        </li>
                    }
                </ul>
            </div>            
        </div>
    </div>
</div>