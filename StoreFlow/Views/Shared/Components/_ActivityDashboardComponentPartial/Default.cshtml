@model List<Activity>

<div class="col-md-4 grid-margin stretch-card">
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-4">
                <i class="mdi mdi-history text-primary mr-2"></i>
                Son Aktiviteler
            </h4>
            <p class="card-description">Sistem genelindeki son hareketleri ve kullanıcı etkinliklerini buradan takip edebilirsiniz.</p>
            
            <ul class="solid-bullet-list">
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <li class="mb-3">
                            <h5 class="font-weight-bold text-dark">
                                @item.Title
                                <span class="float-right text-muted font-weight-normal small">
                                    <i class="mdi mdi-clock-outline mr-1"></i>@item.ActivityTime
                                </span>
                            </h5>
                            <p class="text-muted mb-0 small">@item.Description</p>
                        </li>
                    }
                }
                else
                {
                    <li class="text-center py-4">
                        <i class="mdi mdi-information-outline display-4 text-muted d-block mb-2"></i>
                        <span class="text-muted">Henüz bir aktivite kaydı bulunmuyor.</span>
                    </li>
                }
            </ul>

            <div class="border-top pt-3 mt-2">
                <div class="d-flex justify-content-between align-items-center">
                    <button class="btn btn-sm btn-outline-dark">Daha Fazlası</button>
                    <button class="btn btn-sm btn-primary btn-icon-text">
                        <i class="mdi mdi-plus btn-icon-prepend"></i>
                        Yeni Aktivite Girişi
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>