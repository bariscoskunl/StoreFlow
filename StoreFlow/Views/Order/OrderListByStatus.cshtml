@model List<Order>
@{
    ViewData["Title"] = "OrderListByStatus";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Sipariş Listesi</h3>
                <p class="card-description">Sipariş durumuna göre filtreleme yaparak sonuçları listeleyebilirsiniz.</p>
                
                <div class="mb-4">
                    <form asp-action="OrderListByStatus" method="get" class="form-inline">
                        <div class="input-group mb-2 mr-sm-2">
                            <div class="input-group-prepend">
                                <div class="input-group-text"><i class="mdi mdi-magnify"></i></div>
                            </div>
                            <input type="text" name="status" placeholder="Durum giriniz (Örn: Teslim Edildi)" class="form-control" style="min-width: 300px;" />
                        </div>
                        <button type="submit" class="btn btn-primary mb-2">Sipariş Durumunu Getir</button>
                    </form>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün ID</th>
                                <th>Müşteri ID</th>
                                <th>Birim Fiyat</th>
                                <th>Toplam Fiyat</th>
                                <th>Durum</th>
                                <th class="text-center">Sil</th>
                                <th class="text-center">Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th>@item.OrderId</th>
                                    <td><span class="badge badge-outline-dark">ID: @item.ProductId</span></td>
                                    <td><span class="badge badge-outline-dark">ID: @item.CustomerId</span></td>
                                    <td>@item.UnitPrice.ToString("N2") TL</td>
                                    <td class="font-weight-bold text-dark">@item.TotalPrice.ToString("N2") TL</td>
                                    <td>
                                        @if (item.Status == "Teslim Edildi")
                                        {
                                            <label class="badge badge-success">@item.Status</label>
                                        }
                                        else if (item.Status == "Taşıma Durumunda")
                                        {
                                            <label class="badge badge-warning">@item.Status</label>
                                        }
                                        else if (item.Status == "İptal Edildi")
                                        {
                                            <label class="badge badge-danger">@item.Status</label>
                                        }
                                        else
                                        {
                                            <label class="badge badge-info">@item.Status</label>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Order" asp-action="DeleteOrder" asp-route-id="@item.OrderId" class="btn btn-outline-danger btn-sm">Sil</a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Order" asp-action="UpdateOrder" asp-route-id="@item.OrderId" class="btn btn-outline-success btn-sm">Güncelle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-4">
                        <a asp-controller="Product" asp-action="CreateProduct" class="btn btn-outline-primary">Yeni Ürün Girişi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>