@model List<Order>

@{
    ViewData["Title"] = "OrderListSearch";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Sipariş Listesi Sorgulama</h3>
                <div class="table-responsive">
                    <h4 class="card-description">Duruma Göre Arama İşlemi</h4>

                    <form asp-action="OrderListSearch" method="get" class="mb-4">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Aranacak Durum Metni</label>
                                    <input type="text" name="name" placeholder="Örn: Taşıma Durumunda..." class="form-control" />
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label>Filtre Tipi</label>
                                    <select name="filterType" class="form-control text-dark">
                                        <option value="start">Bu harflerle başlıyorsa</option>
                                        <option value="end">Bu harflerle bitiyorsa</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-2 d-flex align-items-end">
                                <div class="form-group w-100">
                                    <button type="submit" class="btn btn-primary btn-block">Sorgula</button>
                                </div>
                            </div>
                        </div>
                    </form>

                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün ID</th>
                                <th>Müşteri ID</th>
                                <th>Birim Fiyat</th>
                                <th>Toplam Fiyat</th>
                                <th>Durum</th>
                                <th class="text-center">Sil</th>
                                <th class="text-center">Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th>@item.OrderId</th>
                                    <td><span class="badge badge-outline-secondary">ID: @item.ProductId</span></td>
                                    <td><span class="badge badge-outline-secondary">ID: @item.CustomerId</span></td>
                                    <td>@item.UnitPrice.ToString("N2") TL</td>
                                    <td class="font-weight-bold">@item.TotalPrice.ToString("N2") TL</td>
                                    <td>
                                        @if (item.Status == "Teslim Edildi")
                                        {
                                            <label class="badge badge-success">@item.Status</label>
                                        }
                                        else if (item.Status == "Taşıma Durumunda")
                                        {
                                            <label class="badge badge-warning">@item.Status</label>
                                        }
                                        else if (item.Status == "İptal Edildi")
                                        {
                                            <label class="badge badge-danger">@item.Status</label>
                                        }
                                        else
                                        {
                                            <label class="badge badge-info">@item.Status</label>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Order" asp-action="DeleteOrder" asp-route-id="@item.OrderId" class="btn btn-outline-danger btn-sm">Sil</a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Order" asp-action="UpdateOrder" asp-route-id="@item.OrderId" class="btn btn-outline-success btn-sm">Güncelle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-4">
                        <a asp-controller="Product" asp-action="CreateProduct" class="btn btn-outline-primary">Yeni Ürün Girişi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>