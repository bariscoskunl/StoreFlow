@model List<CustomerOrderViewModel>
@{
    ViewData["Title"] = "OrderListWithCustomerGroup";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Müşteri Sipariş Grup Listesi</h3>
                <p class="card-description">Müşterilerin geçmişe dönük siparişlerinin gruplandırılmış dökümü.</p>

                @foreach (var item in Model)
                {
                    <div class="card mb-4 shadow-sm border">
                        <div class="card-header bg-gradient-primary text-white d-flex justify-content-between align-items-center">
                            <span class="font-weight-bold"><i class="mdi mdi-account-circle mr-2"></i>@item.CustomerName</span>
                            <span class="badge badge-light badge-pill text-dark">@item.Orders.Count Sipariş</span>
                        </div>
                        <div class="card-body p-0">
                            @if (item.Orders.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="bg-light">
                                            <tr>
                                                <th class="pl-4">Sipariş No</th>
                                                <th>Ürün ID</th>
                                                <th>Adet</th>
                                                <th>Toplam Tutar</th>
                                                <th>Durum</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var order in item.Orders)
                                            {
                                                <tr>
                                                    <td class="pl-4 font-weight-bold">#@order.OrderId</td>
                                                    <td><span class="badge badge-outline-secondary">@order.ProductId</span></td>
                                                    <td>@order.OrderCount Adet</td>
                                                    <td class="text-dark font-weight-bold">@order.TotalPrice.ToString("N2") TL</td>
                                                    <td>
                                                        <span class="badge badge-info">@order.Status</span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="p-4">
                                    <p class="text-muted mb-0"><i class="mdi mdi-information-outline mr-2"></i>Bu müşteriye ait henüz bir sipariş kaydı bulunmamaktadır.</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>