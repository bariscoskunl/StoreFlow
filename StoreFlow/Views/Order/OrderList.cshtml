@model List<Order>
@{
    ViewData["Title"] = "OrderList";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Asenkron Sipariş Listesi</h3>
                <p class="card-description">Sistemdeki tüm siparişlerin güncel durumlarını ve detaylarını bu alandan takip edebilirsiniz.</p>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Müşteri</th>
                                <th>Sipariş Adedi</th>
                                <th>Toplam Fiyat</th>
                                <th>Durum</th>
                                <th class="text-center">Sil</th>
                                <th class="text-center">Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th>@count</th>
                                    <td class="py-1">
                                        <i class="mdi mdi-package-variant-closed text-primary mr-2"></i>@item.Product.ProductName
                                    </td>
                                    <td>
                                        <i class="mdi mdi-account-circle-outline mr-1"></i>@item.Customer.CustomerName @item.Customer.CustomerSurname
                                    </td>
                                    <td>@item.OrderCount Adet</td>
                                    <td class="font-weight-bold text-dark">@item.TotalPrice.ToString("N2") TL</td>
                                    <td>
                                        @if (item.Status == "Teslim Edildi")
                                        {
                                            <label class="badge badge-success">@item.Status</label>
                                        }
                                        else if (item.Status == "Taşıma Durumunda")
                                        {
                                            <label class="badge badge-warning">@item.Status</label>
                                        }
                                        else if (item.Status == "İptal Edildi")
                                        {
                                            <label class="badge badge-danger">@item.Status</label>
                                        }
                                        else
                                        {
                                            <label class="badge badge-info">@item.Status</label>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Order" asp-action="DeleteOrder" asp-route-id="@item.OrderId" class="btn btn-outline-danger btn-sm">Sil</a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Order" asp-action="UpdateOrder" asp-route-id="@item.OrderId" class="btn btn-outline-success btn-sm">Güncelle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-4">
                        <a asp-controller="Order" asp-action="CreateOrder" class="btn btn-primary">Yeni Sipariş Oluştur</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>