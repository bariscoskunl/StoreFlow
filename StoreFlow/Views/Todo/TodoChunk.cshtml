@model List<Todo[]>
@{
    ViewData["Title"] = "TodoChunk";
    Layout = "~/Views/Layout/Index.cshtml";
    int groupCount = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Chunk Metodu ile Gruplanmış Görevler</h3>
                <p class="card-description">
                    Görev listesi, LINQ <code>Chunk</code> metodu kullanılarak belirli sayılarda kümelere ayrılmıştır.
                </p>

                @foreach (var chunk in Model)
                {
                    groupCount++;
                    <div class="mt-4 mb-4">
                        <h5 class="text-primary d-flex align-items-center">
                            <i class="mdi mdi-layers-outline mr-2"></i> @groupCount. Grup Görevleri
                        </h5>
                        <hr />
                        <div class="row">
                            @foreach (var item in chunk)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card shadow-sm border-left border-warning">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <h6 class="font-weight-bold">@item.Description</h6>
                                                <span class="badge badge-warning badge-pill">Beklemede</span>
                                            </div>
                                            <p class="text-muted small mt-2 mb-0">
                                                <i class="mdi mdi-priority-high text-danger"></i>
                                                Öncelik: <span class="font-weight-medium">@item.Priority</span>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="mt-5 pt-3 border-top">
                    <a asp-action="TodoList" class="btn btn-light btn-icon-text">
                        <i class="mdi mdi-arrow-left btn-icon-prepend"></i> Tüm Listeye Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>