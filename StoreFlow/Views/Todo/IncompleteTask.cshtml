@model IEnumerable<string>
@{
    ViewData["Title"] = "IncompleteTask";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Gün Sonu Kontrolü</h3>
                <p class="card-description">Henüz tamamlanmamış ve kontrol bekleyen günlük görevlerin listesi.</p>
                
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Görev Açıklaması</th>
                                <th style="width: 150px;" class="text-center">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="font-weight-bold">@count</td>
                                        <td>
                                            <i class="mdi mdi-checkbox-blank-circle-outline text-warning mr-2"></i> @item
                                        </td>
                                        <td class="text-center">
                                            <label class="badge badge-outline-warning badge-pill">Beklemede</label>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        <i class="mdi mdi-check-all display-4 d-block mb-2"></i>
                                        Tebrikler! Tamamlanmamış görev bulunmuyor.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-4">
                    <a asp-action="TodoList" class="btn btn-light">Tüm Listeye Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>