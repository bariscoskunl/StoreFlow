@model IEnumerable<Todo>
@{
    ViewData["Title"] = "TodoUnion";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Tekilleştirilmiş Görev Listesi (Union)</h3>
                <p class="card-description">
                    <code>Union</code> metodu kullanılarak iki farklı görev listesi birleştirilmiş ve mükerrer (tekrarlayan) kayıtlar temizlenerek liste tekilleştirilmiştir.
                </p>
                
                <div class="table-responsive">
                    <table class="table table-hover table-bordered">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Görev Açıklaması</th>
                                <th>Öncelik Seviyesi</th>
                                <th class="text-center">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="font-weight-bold">@count</td>
                                        <td>
                                            <i class="mdi mdi-filter-variant text-info mr-2"></i>
                                            @item.Description
                                        </td>
                                        <td>
                                            @if (item.Priority == "Yüksek" || item.Priority == "Acil")
                                            {
                                                <span class="text-danger">
                                                    <i class="mdi mdi-fire mr-1"></i>@item.Priority
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">@item.Priority</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.Status)
                                            {
                                                <span class="badge badge-success">
                                                    <i class="mdi mdi-check mr-1"></i>Tamamlandı
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-outline-secondary">
                                                    <i class="mdi mdi-clock-outline mr-1"></i>İşlem Bekliyor
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">
                                        Gösterilecek herhangi bir benzersiz görev bulunamadı.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 border-top pt-3">
                    <a asp-action="TodoList" class="btn btn-primary btn-icon-text">
                        <i class="mdi mdi-format-list-bulleted btn-icon-prepend"></i>
                        Görev Yönetimine Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>