@model IEnumerable<Todo>
@{
    ViewData["Title"] = "TodoConcat";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Birleştirilmiş Yapılacaklar Listesi</h3>
                <p class="card-description">
                    <code>Concat</code> metodu kullanılarak farklı kaynaklardan gelen görevlerin tek bir listede birleşimi gösterilmektedir.
                </p>
                
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Açıklama</th>
                                <th>Öncelik</th>
                                <th class="text-center">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <td class="font-weight-bold">@count</td>
                                    <td>
                                        <i class="mdi mdi-clipboard-text-outline text-primary mr-2"></i>
                                        @item.Description
                                    </td>
                                    <td>
                                        @if (item.Priority == "Yüksek" || item.Priority == "Acil")
                                        {
                                            <span class="text-danger font-weight-bold">
                                                <i class="mdi mdi-arrow-up-bold mr-1"></i>@item.Priority
                                            </span>
                                        }
                                        else if (item.Priority == "Orta")
                                        {
                                            <span class="text-warning font-weight-bold">
                                                <i class="mdi mdi-minus-box mr-1"></i>@item.Priority
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-info font-weight-bold">
                                                <i class="mdi mdi-arrow-down-bold mr-1"></i>@item.Priority
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (item.Status)
                                        {
                                            <label class="badge badge-success badge-pill">Tamamlandı</label>
                                        }
                                        else
                                        {
                                            <label class="badge badge-warning badge-pill">Beklemede</label>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-4">
                    <a asp-action="TodoList" class="btn btn-outline-primary btn-icon-text">
                        <i class="mdi mdi-keyboard-backspace btn-icon-prepend"></i>
                        Listeye Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>