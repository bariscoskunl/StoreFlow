@model List<StoreFlow.Entities.Todo>
@{
    ViewData["Title"] = "TodoList";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h3 class="card-title">Genel Görev Listesi</h3>
                        <p class="card-description">Sistemde kayıtlı olan tüm görevlerin detaylı dökümü.</p>
                    </div>
                    <a asp-action="CreateToDo" class="btn btn-gradient-primary btn-icon-text">
                        <i class="mdi mdi-plus btn-icon-prepend"></i> Örnek Veri Yükle
                    </a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Görev Açıklaması</th>
                                <th>Öncelik Seviyesi</th>
                                <th class="text-center">Durum</th>
                                <th class="text-right">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="font-weight-bold">@count</td>
                                        <td>
                                            <i class="mdi mdi-file-document-outline text-primary mr-2"></i> @item.Description
                                        </td>
                                        <td>
                                            @if (item.Priority == "Birincil")
                                            {
                                                <label class="badge badge-danger">@item.Priority</label>
                                            }
                                            else if (item.Priority == "Ikincil")
                                            {
                                                <label class="badge badge-info">@item.Priority</label>
                                            }
                                            else
                                            {
                                                <label class="badge badge-light text-dark">@item.Priority</label>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.Status)
                                            {
                                                <div class="badge badge-success badge-pill">
                                                    <i class="mdi mdi-check"></i> Tamamlandı
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="badge badge-warning badge-pill text-white">
                                                    <i class="mdi mdi-clock-outline"></i> Beklemede
                                                </div>
                                            }
                                        </td>
                                        <td class="text-right">
                                            <button class="btn btn-sm btn-outline-dark btn-icon">
                                                <i class="mdi mdi-pencil"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger btn-icon">
                                                <i class="mdi mdi-delete"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="text-muted">
                                            <i class="mdi mdi-database-off display-3 d-block mb-3"></i>
                                            Henüz hiçbir görev kaydı bulunamadı.
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>