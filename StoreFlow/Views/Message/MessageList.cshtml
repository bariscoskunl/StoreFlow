@model List<Message>

@{
    ViewData["Title"] = "MessageList";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Mesaj Listesi</h3>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Gönderen</th>
                                <th>Konu</th>
                                <th>Durum</th>
                                <th>Tarih</th>
                                <th class="text-center">Sil</th>
                                <th class="text-center">Güncelle</th>
                                <th class="text-center">Mesajı Aç</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th>@count</th>
                                    <td class="py-1">
                                        <i class="mdi mdi-account-outline mr-2 text-primary"></i>@item.SenderNameSurname
                                    </td>
                                    <td>@item.MessageTitle</td>
                                    <td>
                                        @if (item.IsRead)
                                        {
                                            <span class="badge badge-success badge-pill">Okundu</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger badge-pill">Okunmadı</span>
                                        }
                                    </td>
                                    <td>@item.Datetime.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <a asp-controller="Message" asp-action="DeleteMessage" asp-route-id="@item.MessageId" class="btn btn-outline-danger btn-sm">Sil</a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Message" asp-action="UpdateMessage" asp-route-id="@item.MessageId" class="btn btn-outline-success btn-sm">Güncelle</a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Message" asp-action="ReadMessage" asp-route-id="@item.MessageId" class="btn btn-outline-warning btn-sm">Mesajı Aç</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-4">
                        <a asp-controller="Message" asp-action="CreateMessage" class="btn btn-primary">Yeni Mesaj Girişi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>