@model List<IGrouping<string, Customer>>

@{
    ViewData["Title"] = "CustomerListByCity";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Şehre Göre Müşteri Listesi</h4>
                <p class="card-description">Sistemdeki müşterilerin şehirlere göre gruplandırılmış dökümü.</p>
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 200px;">Şehir</th>
                                <th>Müşteri Bilgileri</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var group in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold text-primary">
                                        <i class="mdi mdi-city mr-2"></i>@group.Key
                                    </td>
                                    <td>
                                        <div class="d-flex flex-wrap">
                                            @foreach (var customer in group)
                                            {
                                                <div class="badge badge-outline-dark mr-2 mb-1">
                                                    <i class="mdi mdi-account mr-1"></i>
                                                    @customer.CustomerName @customer.CustomerSurname
                                                </div>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>