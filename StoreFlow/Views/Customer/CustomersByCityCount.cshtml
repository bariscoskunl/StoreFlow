@model List<CustomerCityGroup>
@{
    ViewData["Title"] = "CustomersByCityCount";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Müşteri Şehir Sayıları</h3>
                <p class="card-description">Şehir bazlı toplam müşteri dağılımı listelenmektedir.</p>
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Şehir Adı</th>
                                <th>Müşteri Sayısı</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold text-dark">
                                        <i class="mdi mdi-city text-primary mr-2"></i>@item.City
                                    </td>
                                    <td>
                                        <label class="badge badge-primary badge-pill">@item.CustomerCount Kişi</label>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>