@model List<Product>
@{
    ViewData["Title"] = "First4ProductList";
    Layout = "~/Views/Layout/Index.cshtml";
}




<div class="col-lg-12 grid-margin stretch-card">
    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="card-title">
                <i class="mdi mdi-numeric-4-box-outline text-primary mr-2"></i>
                Sisteme Kayıtlı İlk 4 Ürün
            </h4>
            <p class="card-description">ID sırasına göre listelenen ilk 4 ürünün detayları.</p>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th class="font-weight-bold">Ürün Adı</th>
                            <th class="font-weight-bold">Kategori</th>
                            <th class="font-weight-bold">Birim Fiyat</th>
                            <th class="font-weight-bold text-center">Stok Durumu</th>
                            <th class="text-right">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="py-2 text-dark font-weight-medium">
                                    <i class="mdi mdi-label-outline text-muted small mr-1"></i> @item.ProductName
                                </td>
                                <td>
                                    <label class="badge badge-outline-secondary">@item.Category.CategoryName</label>
                                </td>
                                <td>
                                    <span class="text-primary font-weight-bold">@item.ProductPrice.ToString("C2")</span>
                                </td>
                                <td class="text-center">
                                    @if (item.ProductStock <= 10)
                                    {
                                        <label class="badge badge-danger badge-pill">Kritik: @item.ProductStock</label>
                                    }
                                    else
                                    {
                                        <label class="badge badge-success badge-pill">@item.ProductStock Adet</label>
                                    }
                                </td>
                                <td class="text-right">
                                    <a asp-action="UpdateProduct" asp-route-id="@item.ProductId" class="btn btn-sm btn-outline-warning">Düzenle</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
