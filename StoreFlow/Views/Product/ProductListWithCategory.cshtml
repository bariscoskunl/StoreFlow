@model List<ProductWithCategoryViewModel>
@{
    ViewData["Title"] = "ProductListWithCategory";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Ürün Listesi (Kategorileri İle)</h3>
                <p class="card-description">ViewModel kullanılarak ürünlerin ait oldukları kategorilerle birlikte listelendiği raporlama sayfasıdır.</p>
                
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th style="width: 50px;">#</th>
                                <th>Ürün Adı</th>
                                <th class="text-center">Stok Sayısı</th>
                                <th>Kategori Bilgisi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <td class="font-weight-bold">@count</td>
                                    <td>
                                        <i class="mdi mdi-package-variant text-primary mr-2"></i>@item.ProductName
                                    </td>
                                    <td class="text-center">
                                        @if (item.ProductStock <= 5)
                                        {
                                            <span class="badge badge-danger badge-pill">@item.ProductStock Adet</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-outline-dark badge-pill">@item.ProductStock Adet</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="badge badge-info d-inline-flex align-items-center">
                                            <i class="mdi mdi-tag-outline mr-1"></i> @item.CategoryName
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>