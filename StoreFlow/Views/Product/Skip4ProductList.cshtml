@model List<Product>

@{
    ViewData["Title"] = "Skip4ProductList";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">Ürün Listesi (Sayfalama Örneği)</h3>
                <p class="card-description">
                    Sistemdeki ilk 4 kayıt atlanarak, sonraki 10 kayıt listelenmektedir.
                </p>
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Fiyat</th>
                                <th>Kategori</th>
                                <th class="text-center">Stok Sayısı</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th class="align-middle">@count</th>
                                    <td class="align-middle font-weight-bold">
                                        <i class="mdi mdi-package-variant-closed text-info mr-2"></i>@item.ProductName
                                    </td>
                                    <td class="align-middle text-dark">
                                        @item.ProductPrice.ToString("N2") TL
                                    </td>
                                    <td class="align-middle">
                                        <label class="badge badge-outline-primary">@item.Category.CategoryName</label>
                                    </td>
                                    <td class="align-middle text-center">
                                        @if (item.ProductStock < 20)
                                        {
                                            <span class="text-warning font-weight-bold">
                                                <i class="mdi mdi-alert-outline mr-1"></i>@item.ProductStock
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-success font-weight-bold">@item.ProductStock</span>
                                        }
                                    </td>
                                    <td class="align-middle text-center">
                                        <div class="btn-group">
                                            <a asp-controller="Product" asp-action="UpdateProduct" asp-route-id="@item.ProductId" class="btn btn-outline-success btn-sm">
                                                <i class="mdi mdi-pencil"></i>
                                            </a>
                                            <a asp-controller="Product" asp-action="DeleteProduct" asp-route-id="@item.ProductId" class="btn btn-outline-danger btn-sm">
                                                <i class="mdi mdi-trash-can-outline"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-4">
                        <a asp-controller="Product" asp-action="CreateProduct" class="btn btn-primary">
                            <i class="mdi mdi-plus mr-1"></i>Yeni Ürün Girişi
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>