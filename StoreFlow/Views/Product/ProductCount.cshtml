@{
    ViewData["Title"] = "ProductCount";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-md-4 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Toplam Ürün Sayısı</h4>
                <div class="d-flex align-items-center mt-4">
                    <div class="bg-gradient-info p-3 rounded mr-3">
                        <i class="mdi mdi-cube-outline text-white icon-md"></i>
                    </div>
                    <div>
                        <p class="text-muted mb-1">Kayıtlı Ürün Adedi</p>
                        <h2 class="font-weight-bold mb-0 text-primary">@ViewBag.v</h2>
                    </div>
                </div>
                <div class="mt-4 pt-3 border-top">
                    <p class="text-small text-muted">Sistemdeki aktif ve pasif tüm ürünlerin toplam miktarını ifade eder.</p>
                </div>
                <div class="mt-3">
                    <a asp-action="ProductList" class="btn btn-sm btn-outline-primary btn-block">Tüm Ürünleri Gör</a>
                </div>
            </div>
        </div>
    </div>
</div>