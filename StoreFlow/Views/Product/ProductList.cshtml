@model List<Product>
@{
    ViewData["Title"] = "ProductList";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="card-title mb-0">Ürün Listesi</h3>
                    <a asp-controller="Product" asp-action="CreateProduct" class="btn btn-primary btn-sm">
                        <i class="mdi mdi-plus mr-1"></i>Yeni Ürün Girişi
                    </a>
                </div>
                
                <p class="card-description">Sistemde kayıtlı olan tüm ürünlerin fiyat, stok ve kategori bilgilerini buradan yönetebilirsiniz.</p>
                
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Fiyat</th>
                                <th>Kategori</th>
                                <th class="text-center">Stok Sayısı</th>
                                <th class="text-center">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <th class="align-middle">@item.ProductId</th>
                                    <td class="align-middle font-weight-bold">
                                        <i class="mdi mdi-cube-send text-primary mr-2"></i>@item.ProductName
                                    </td>
                                    <td class="align-middle">
                                        <span class="text-dark">@item.ProductPrice.ToString("N2") TL</span>
                                    </td>
                                    <td class="align-middle">
                                        <span class="badge badge-outline-dark">@item.Category.CategoryName</span>
                                    </td>
                                    <td class="align-middle text-center">
                                        @if (item.ProductStock <= 10)
                                        {
                                            <span class="badge badge-danger badge-pill">@item.ProductStock (Düşük Stok)</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success badge-pill">@item.ProductStock</span>
                                        }
                                    </td>
                                    <td class="align-middle text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-controller="Product" asp-action="UpdateProduct" asp-route-id="@item.ProductId" class="btn btn-outline-success btn-sm" title="Güncelle">
                                                <i class="mdi mdi-pencil"></i>
                                            </a>
                                            <a asp-controller="Product" asp-action="DeleteProduct" asp-route-id="@item.ProductId" class="btn btn-outline-danger btn-sm" title="Sil">
                                                <i class="mdi mdi-delete"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>