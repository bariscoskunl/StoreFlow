@model Product
@{
    ViewData["Title"] = "CreateProductWithAttach";
    Layout = "~/Views/Layout/Index.cshtml";
}

<div class="row">
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Yeni Ürün Ekleme Sayfası (Attach Metodu)</h4>
                <p class="card-description">Entity State yönetimi kullanılarak sisteme yeni ürün girişi yapılması sağlanır.</p>
                
                <form class="forms-sample" method="post">
                    <div class="form-group">
                        <label for="ProductName">Ürün Adı</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-info text-white">
                                    <i class="mdi mdi-tag-text-outline"></i>
                                </span>
                            </div>
                            <input type="text" class="form-control" id="ProductName" placeholder="Ürün Adını Yazınız" asp-for="ProductName" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="ProductPrice">Ürün Fiyatı</label>
                                <div class="input-group">
                                    <input type="number" step="0.01" class="form-control" id="ProductPrice" placeholder="0.00" asp-for="ProductPrice" required />
                                    <div class="input-group-append">
                                        <span class="input-group-text bg-light text-dark">TL</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="ProductStock">Stok Sayısı</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" id="ProductStock" placeholder="0" asp-for="ProductStock" required />
                                    <div class="input-group-append">
                                        <span class="input-group-text bg-light text-dark">Adet</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary mr-2">
                            <i class="mdi mdi-content-save mr-1"></i> Ürünü Kaydet
                        </button>
                        <a asp-action="ProductList" class="btn btn-light">Listeye Dön</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>