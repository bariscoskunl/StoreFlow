@model List<Product>
@{
    ViewData["Title"] = "First5ProductList";
    Layout = "~/Views/Layout/Index.cshtml";
    int count = 0;
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h3 class="card-title">İlk 5 Ürün Listesi</h3>
                <p class="card-description">Sistemde kayıtlı olan ilk 5 ürünün detaylı dökümü listelenmektedir.</p>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Fiyat</th>
                                <th>Kategori</th>
                                <th class="text-center">Stok Sayısı</th>
                                <th class="text-center">Sil</th>
                                <th class="text-center">Güncelle</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                count++;
                                <tr>
                                    <th>@count</th>
                                    <td>
                                        <i class="mdi mdi-cube-outline text-primary mr-2"></i> @item.ProductName
                                    </td>
                                    <td class="font-weight-bold text-dark">
                                        @item.ProductPrice.ToString("N2") TL
                                    </td>
                                    <td>
                                        <label class="badge badge-outline-info">@item.Category.CategoryName</label>
                                    </td>
                                    <td class="text-center">
                                        @if (item.ProductStock < 10)
                                        {
                                            <span class="text-danger font-weight-bold">@item.ProductStock (Kritik)</span>
                                        }
                                        else
                                        {
                                            <span>@item.ProductStock</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Product" asp-action="DeleteProduct" asp-route-id="@item.ProductId" class="btn btn-outline-danger btn-sm">Sil</a>
                                    </td>
                                    <td class="text-center">
                                        <a asp-controller="Product" asp-action="UpdateProduct" asp-route-id="@item.ProductId" class="btn btn-outline-success btn-sm">Güncelle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <div class="mt-4">
                        <a asp-controller="Product" asp-action="CreateProduct" class="btn btn-primary">Yeni Ürün Girişi</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>